# Terraform (never commit state or plans — .terraform.lock.hcl IS committed)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
tfplan*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
!*.tfvars.example

# Node
node_modules/
dist/
coverage/
npm-debug.log*

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Env & secrets
.env
.env.*
!.env.example

# OS
Thumbs.db
.DS_Store

# IDE
.idea/
.vscode/
*.iml
.coverage
