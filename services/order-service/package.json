{
  "name": "order-service",
  "version": "0.1.0",
  "description": "MakanLah order-service: order placement with SQS OrderPlaced events",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --coverage",
    "lint": "eslint src tests"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1080.0",
    "@aws-sdk/client-sqs": "^3.1080.0",
    "@aws-sdk/lib-dynamodb": "^3.1080.0",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
